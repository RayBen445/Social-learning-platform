# LearnLoop Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# REQUIRED: Supabase Configuration
# ============================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# OPTIONAL: Email Configuration
# ============================================
# For password reset and notification emails
NEXT_PUBLIC_MAIL_FROM=noreply@learnloop.app
MAIL_API_KEY=your_email_api_key

# ============================================
# SYSTEM ACCOUNTS (Development/Testing)
# ============================================
# Bot account for automated features
NEXT_PUBLIC_BOT_EMAIL=bot@learnloop.app
BOT_PASSWORD=your_generated_bot_password
NEXT_PUBLIC_BOT_USER_ID=your_bot_user_id_from_auth

# Admin account for moderation
NEXT_PUBLIC_ADMIN_EMAIL=admin@learnloop.app
ADMIN_PASSWORD=your_generated_admin_password
NEXT_PUBLIC_ADMIN_USER_ID=your_admin_user_id_from_auth

# ============================================
# AUTHENTICATION REDIRECTS
# ============================================
# Development
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# Production
NEXT_PUBLIC_PROD_SUPABASE_REDIRECT_URL=https://your-domain.com/auth/callback

# ============================================
# FEATURE FLAGS
# ============================================
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_MESSAGING=true
NEXT_PUBLIC_ENABLE_GAMIFICATION=true

# ============================================
# OPTIONAL: Analytics & Monitoring
# ============================================
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# OPTIONAL: File Storage (Vercel Blob)
# ============================================
BLOB_READ_WRITE_TOKEN=

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
